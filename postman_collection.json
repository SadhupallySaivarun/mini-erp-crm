{
  "info": {
    "name": "Mini ERP + CRM Operations Portal",
    "description": "Complete API collection for the Mini ERP + CRM Operations Portal. Set the `baseUrl` and `token` collection variables (token is auto-set after login).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "challanId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.data && data.data.token) { pm.collectionVariables.set('token', data.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@erpcrm.test\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/customers?page=1&limit=10&search=&status="
          }
        },
        {
          "name": "Create Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.data && data.data.id) { pm.collectionVariables.set('customerId', data.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya Enterprises\",\n  \"mobile\": \"9988776655\",\n  \"email\": \"priya@enterprises.com\",\n  \"businessName\": \"Priya Enterprises Pvt Ltd\",\n  \"gstNumber\": \"27ABCDE5678F1Z9\",\n  \"customerType\": \"DISTRIBUTOR\",\n  \"address\": \"45 Park Street, Kolkata\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/customers"
          }
        },
        {
          "name": "Get Customer By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/customers/{{customerId}}"
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACTIVE\",\n  \"followUpDate\": \"2026-08-01T00:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/customers/{{customerId}}"
          }
        },
        {
          "name": "Add Follow-up Note",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Called customer, interested in bulk order next month.\"\n}"
            },
            "url": "{{baseUrl}}/customers/{{customerId}}/follow-up-notes"
          }
        },
        {
          "name": "Delete Customer",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/customers/{{customerId}}"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/products?page=1&limit=10"
          }
        },
        {
          "name": "Low Stock Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/products/low-stock"
          }
        },
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.data && data.data.id) { pm.collectionVariables.set('productId', data.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Steel Washer 10mm\",\n  \"sku\": \"SKU-003\",\n  \"category\": \"Hardware\",\n  \"unitPrice\": 1.5,\n  \"currentStock\": 200,\n  \"minStockAlert\": 25,\n  \"location\": \"Warehouse A\"\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Get Product By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitPrice\": 1.75\n}"
            },
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "List Stock Movements For Product",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/inventory/movements/{{productId}}"
          }
        },
        {
          "name": "Record Stock Movement (IN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 100,\n  \"movementType\": \"IN\",\n  \"reason\": \"New stock arrival from supplier\"\n}"
            },
            "url": "{{baseUrl}}/inventory/movements"
          }
        },
        {
          "name": "Record Stock Movement (OUT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 10,\n  \"movementType\": \"OUT\",\n  \"reason\": \"Damaged goods write-off\"\n}"
            },
            "url": "{{baseUrl}}/inventory/movements"
          }
        }
      ]
    },
    {
      "name": "Sales Challans",
      "item": [
        {
          "name": "List Challans",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/challans?page=1&limit=10"
          }
        },
        {
          "name": "Create Challan (Draft)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.data && data.data.id) { pm.collectionVariables.set('challanId', data.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"status\": \"DRAFT\",\n  \"items\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 5 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/challans"
          }
        },
        {
          "name": "Get Challan By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/challans/{{challanId}}"
          }
        },
        {
          "name": "Update Draft Challan",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 8 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/challans/{{challanId}}"
          }
        },
        {
          "name": "Confirm Challan",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/challans/{{challanId}}/confirm"
          }
        },
        {
          "name": "Cancel Challan",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/challans/{{challanId}}/cancel"
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    }
  ]
}
